---
import { langPrefix, loc, type Lang } from "../lib/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const L = loc(lang);
const p = langPrefix(lang);
---

<section id="hero" class="hero">
  <div class="bg"></div>
  <div class="glow"></div>
  <div class="content">
    <div class="kicker">{L.hero.subtitle}</div>
    <h1>{L.hero.title1}<br />{L.hero.title2}</h1>
    <p>{L.hero.description}</p>
    <div class="actions">
      <a class="btn btn-rust" href={`${p}/oplevelser/`}>{L.hero.exploreBtn}</a>
      <a class="btn ghost" href="#huset">{L.hero.houseBtn}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 520px;
    overflow: hidden;
    background: var(--deep);
  }
  .bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1a2a3a 0%, #2c3e50 30%, #3d4f5f 60%, #1a2a3a 100%);
  }
  .glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 80%, rgba(184, 98, 76, 0.15) 0%, transparent 60%);
  }
  .content {
    position: absolute;
    bottom: 13%;
    left: 28px;
    right: 28px;
    z-index: 10;
    animation: fadeUp 0.8s ease 0.3s both;
  }
  .kicker {
    margin-bottom: 12px;
  }
  h1 {
    font-size: clamp(32px, 6vw, 64px);
    font-weight: 400;
    color: var(--foam);
    line-height: 1.05;
    max-width: 600px;
  }
  p {
    font-size: 15px;
    color: rgba(245, 240, 232, 0.5);
    margin-top: 16px;
    max-width: 440px;
    line-height: 1.7;
  }
  .actions {
    display: flex;
    gap: 12px;
    margin-top: 26px;
    flex-wrap: wrap;
  }
  .ghost {
    color: var(--foam);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.15);
    font-weight: 500;
  }
</style>
