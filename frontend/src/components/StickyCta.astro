---
import { loc, type Lang } from "../lib/i18n";
import { BOOKING } from "../lib/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const L = loc(lang);
---

<div class="sticky-cta" id="sticky-cta">
  <div class="left">
    <div class="dot"></div>
    <span>{L.sticky.text}</span>
  </div>
  <a
    href={BOOKING}
    target="_blank"
    rel="noopener noreferrer"
    onclick="window.fbq&&fbq('track','Contact')"
  >
    {L.sticky.cta}
  </a>
</div>

<style>
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    background: linear-gradient(135deg, var(--deep), var(--storm));
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 10px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .sticky-cta.visible {
    transform: translateY(0);
  }
  .left {
    display: flex;
    align-items: center;
    gap: 9px;
    color: var(--foam);
    font-size: 12px;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--rust);
    animation: pulse 2s infinite;
  }
  a {
    background: var(--rust);
    color: var(--foam);
    padding: 8px 18px;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
  }
</style>

<script>
  const bar = document.getElementById("sticky-cta");
  if (bar) {
    const onScroll = () =>
      bar.classList.toggle("visible", window.scrollY > window.innerHeight * 0.5);
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
