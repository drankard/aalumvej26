---
import { langPrefix, loc, pickTr, type Lang } from "../lib/i18n";
import { TAG_COLORS } from "../lib/site";
import type { Post, PostTranslation } from "../lib/types";

interface Props {
  post: Post;
  lang: Lang;
  slug: string;
  /** Archived posts have no detail page; the card links to the external source. */
  external?: boolean;
  idx?: number;
}

const { post, lang, slug, external = false, idx = 0 } = Astro.props;
const L = loc(lang);
const tr = pickTr<PostTranslation>(post.translations, lang);
const bg = TAG_COLORS[post.tag_key] || "#5A7A8A";
const tag = (L.tags as Record<string, string>)[post.tag_key] ?? post.tag_key;
const href = external ? post.url : `${langPrefix(lang)}/oplevelser/${slug}/`;
---

<a
  class="card"
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer nofollow" : undefined}
  style={`animation-delay: ${idx * 0.05}s`}
>
  <div class="head" style={`background: linear-gradient(135deg, ${bg}33, #2C3E5022)`}>
    {post.emoji}
  </div>
  <div class="body">
    <div class="meta">
      <span class="tag" style={`background:${bg}`}>{tag}</span>
      <span class="date">{tr.date}</span>
    </div>
    <h3>{tr.title}</h3>
    <p>{tr.excerpt}</p>
    <div class="more">{L.experiences.readMore}</div>
  </div>
</a>

<style>
  .card {
    display: block;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 2px 10px rgba(44, 62, 80, 0.05);
    animation: fadeUp 0.45s ease both;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(44, 62, 80, 0.12);
    opacity: 1;
  }
  .head {
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
  }
  .body {
    padding: 20px 22px 24px;
  }
  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .date {
    font-size: 11px;
    color: var(--driftwood);
  }
  h3 {
    font-size: 18px;
    margin: 0 0 8px;
    line-height: 1.3;
  }
  p {
    font-size: 13px;
    color: var(--storm);
    line-height: 1.65;
    margin: 0;
    opacity: 0.75;
  }
  .more {
    margin-top: 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--rust);
  }
</style>
