---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AreaCard from "../components/AreaCard.astro";
import HouseCrossSell from "../components/HouseCrossSell.astro";
import { getContent } from "../lib/content";
import { langPrefix, loc, pickTr, ui, type Lang } from "../lib/i18n";
import { SITE } from "../lib/site";
import type { AreaTranslation } from "../lib/types";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const L = loc(lang);
const U = ui(lang);
const p = langPrefix(lang);
const { areas, areaSlugs } = await getContent();

const basePath = "/omraadet/";
const title = `${U.allAreas} — Aalumvej 26, Agger · Nationalpark Thy`;
const description = `${U.allAreas}: ${U.intro}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: U.allAreas,
    itemListElement: areas.map((area, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: pickTr<AreaTranslation>(area.translations, lang).name,
      url: `${SITE}${p}/omraadet/${areaSlugs.get(area.id)}/`,
    })),
  },
];
---

<Base lang={lang} title={title} description={description} basePath={basePath} jsonLd={jsonLd}>
  <main class="page">
    <div class="container">
      <Breadcrumbs lang={lang} trail={[{ label: L.nav.area }]} />
      <div class="kicker">{L.areas.subtitle}</div>
      <h1>{L.areas.heading1}<em>{L.areas.heading2}</em></h1>
      <p class="intro">{U.intro}</p>
      <div class="cards">
        {areas.map((area) => (
          <AreaCard area={area} lang={lang} slug={areaSlugs.get(area.id)!} />
        ))}
      </div>
      <HouseCrossSell lang={lang} />
    </div>
  </main>
</Base>

<style>
  .page {
    padding: 110px 28px 72px;
    background: var(--foam);
    min-height: 60vh;
  }
  h1 {
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 400;
    margin-bottom: 10px;
  }
  h1 em {
    font-style: italic;
    color: var(--sea);
  }
  .intro {
    font-size: 14px;
    opacity: 0.75;
    margin-bottom: 28px;
    max-width: 560px;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 14px;
  }
</style>
