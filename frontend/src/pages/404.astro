---
import Base from "../layouts/Base.astro";
import { ui } from "../lib/i18n";

const U = ui("da");
---

<Base
  lang="da"
  title="404 — Aalumvej 26"
  description={U.notFoundTitle}
  basePath="/404.html"
  noindex
>
  <main class="page">
    <div class="container">
      <div class="kicker">404</div>
      <h1>{U.notFoundTitle}</h1>
      <p>{U.notFoundText}</p>
      <div class="links">
        <a class="btn btn-deep" href="/">Forside</a>
        <a class="btn btn-rust" href="/oplevelser/">Oplevelser</a>
        <a class="btn btn-rust" href="/omraadet/">Området</a>
      </div>
    </div>
  </main>
</Base>

<style>
  .page {
    padding: 140px 28px 100px;
    background: var(--foam);
    min-height: 70vh;
  }
  h1 {
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 400;
    margin-bottom: 10px;
  }
  p {
    font-size: 14px;
    opacity: 0.75;
    margin-bottom: 28px;
  }
  .links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
</style>
