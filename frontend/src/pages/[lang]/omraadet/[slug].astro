---
import AreaPage from "../../../pageviews/AreaPage.astro";
import { getContent } from "../../../lib/content";
import type { Lang } from "../../../lib/i18n";

export async function getStaticPaths() {
  const { areas, areaSlugs } = await getContent();
  return ["en", "de"].flatMap((lang) =>
    areas.map((area) => ({
      params: { lang, slug: areaSlugs.get(area.id)! },
      props: { area },
    }))
  );
}

const { area } = Astro.props;
const { lang, slug } = Astro.params;
---

<AreaPage lang={lang as Lang} area={area} slug={slug!} />
